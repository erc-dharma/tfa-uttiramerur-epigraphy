        <body>
            
            <div type="edition" xml:lang="tam-Latn" rendition="class:tamil maturity:83215">
                
                <ab>
                    <lb n="1"/><hi rend="grantha">svasti śrī</hi>
                </ab>
                
                <lg>
                    <l n="1">tirumakaḷ pōla<choice><sic>pe</sic><corr>-p</corr></choice> p<choice><sic>a</sic><corr>e</corr></choice>runila-c-celviyu<choice><sic>ṉ</sic><corr>n</corr></choice></l>
                    <l n="2">taṉakkē y-urim<hi rend="grantha">ai</hi> pūṇṭam<hi rend="grantha">ai</hi> maṉakkoḷa</l>
                    <l n="3">kāntaḷūr cālai kalamarutt-aruḷi</l>
                    <l n="4">vēṅkai-nāṭuṅ kaṅka-pāṭiyu<supplied reason="subaudible">m</supplied></l>
                    <l n="5"><choice><sic>ṉ</sic><corr>n</corr></choice>uḷampa-pāṭiyu<supplied reason="subaudible">m</supplied> taṭik<hi rend="grantha">ai</hi>-pāṭiyuṅ</l>
                    <l n="6">kuṭamalai-<choice><sic>ṉ</sic><corr>n</corr></choice>āṭuṅ kollamuṅ kaliṅkamum</l>
                    <l n="7">Eṇ-ṭicai puka<lb n="2" break="no"/>ḻ tara Īḻamaṇṭalamum</l>
                    <l n="8">tiṇtiṟal ve<choice><sic>n</sic><corr>ṉ</corr></choice>ṟi taṇṭā<supplied reason="omitted">l</supplied> <hi rend="grantha">ko</hi>ṇṭa taṉṉ</l>
                    <l n="9">eḻil vaḷar <choice><orig>u</orig><reg>ū</reg></choice>ḻi El<unclear reason="eccentric_ductus">lā</unclear> yāṇṭun</l>
                    <l n="10">toḻutaka viḷaṅkum yāṇṭē</l>
                    <l n="11">ceḻiyarait tēcu koḷ</l>
                </lg>
                <p>
                    kō-rā<hi rend="grantha">ja</hi>rā<hi rend="grantha">ja</hi>-ke<hi rend="grantha">sa</hi>ri-pa<hi rend="grantha">nmā</hi>r-ākiya <hi rend="grantha">śrī-rāja-rāja</hi>-tēvaṟku yāṇṭu Irupatt’ o<choice><sic>n</sic><corr>ṉ</corr></choice>r-āvatu
                </p>
                
                <p>
                    kāliyūr-k=-koṭṭattu taṉ-kūṟṟ’ uttarameru-c-catu<hi rend="grantha"><reg>r</reg>vvedi</hi>
                    <lb n="3" break="no"/>-maṅkalattu <hi rend="grantha">śrī</hi>-veli-vi<hi rend="grantha">ṣṇu-gṛha</hi>ttu veḷḷai-m<choice><sic>u</sic><corr>ū</corr></choice><seg rend="check">rtti</seg>-y-āḻvārk=ku <hi rend="grantha">śrī</hi>-<choice><sic>ṉ</sic><corr>n</corr></choice>ār<choice><sic>a</sic><corr>ā</corr></choice>yaṇa-c-cēri-kilākkil caṉṉacaṭṭi <hi rend="grantha">kra</hi>mavitta<supplied reason="omitted">ṉ</supplied> vaitta <choice><sic>ṉ</sic><corr>n</corr></choice>antā-viḷakku Oṉṟiṉāl Āṭu toṇṇūṟṟ’ āṟu</p>
                
                <p>
                    It-toṇṇūṟṟ’ āṟukkum I<choice><orig>v</orig><reg>vv</reg></choice>-ūr periḷamaiyārē puṇai-y-ā<supplied reason="omitted">ka</supplied>-c cāvā m<choice><orig>u</orig><reg>ū</reg></choice>vā-p pēr-āṭ’ āka <hi rend="grantha">candrādityā</hi>vaṟ nicatam Uḻak=ku <choice><sic>n</sic><corr>n</corr></choice>ey muṭṭāmai Aṭṭuvippārkaḷ āka muṭṭil <hi rend="grantha">śraddha</hi>mantarum <hi rend="grantha">śrī-vaiṣṇa</hi>varumē <hi rend="grantha">da<unclear reason="eccentric_ductus">ṇḍ</unclear>i</hi>ppār <choice><sic>a</sic><corr>ā</corr></choice>ka v<choice><sic>a</sic><corr>ai</corr></choice>ttōm <hi rend="grantha">mahāsabhai</hi>yōm
                </p>
                
            </div>
            
