        <body>
            
            <div type="edition" xml:lang="tam-Latn" rendition="class:tamil maturity:83215">
                
                <ab>
                    <lb n="1"/><hi rend="grantha">svasti śrī</hi>
                </ab>
                
                <lg>
                    <l n="1">tirumakaḷ pōla peru-nilai-c-cel<choice><sic>vv</sic><corr>v</corr></choice>iyun=</l>
                    <l n="2">taṉakkē y-urimai pūṇṭamai maṉakkoḷa</l>
                    <l n="3">kān=taḷūr cālai <lb n="2"/>kalam arutt-aruḷi</l>
                    <l n="4">vēṅkai-nāṭuṅ kaṅka-pāṭiyu<choice><sic>ṉ</sic><corr>n</corr></choice></l>
                    <l n="5"><choice><sic>ṉ</sic><corr>n</corr></choice>uḷampa-pāṭiyum taṭikai-pāṭiyuṅ</l>
                    <l n="6"><choice><sic>ṉ</sic><corr>n</corr></choice>uḷampa-pāṭiyum kollamuṅ kaliṅkamu<lb n="3" break="no"/>m</l>
                    <l n="7">Eṇ-ṭicai pukaḻ <supplied reason="omitted">tara</supplied> Īḻa-maṇṭalamum</l>
                    <l n="8">tiṇṭiṟal veṉṟi taṇṭāṟ koṇṭa taṉṉ</l>
                    <l n="9">eḻil vaḷar <choice><orig>u</orig><reg>ū</reg></choice>ḻiUḷḷ ellā yāṇṭun</l>
                    <l n="10">toḻutakai viḷaṅkum yāṇṭē-y</l>
                    <l n="11"><choice><sic>t</sic><corr>c</corr></choice>eḻiyarai <lb n="4"/>tēcu koḷ</l>
                </lg>
                <p>
                    <hi rend="grantha">śrī</hi>-kō-v-i<hi rend="grantha">rāja-rāja-rāja-kesari-panma</hi>kku yāṇṭu Irupatt’ o<choice><sic>n</sic><corr>ṉ</corr></choice>r-āvatu
                </p>
                
                <p>
                    kāliyūr-k=-kōṭṭattu taṉ kūṟṟ’ uttara-mēru-c-catu<hi rend="grantha"><reg>r</reg>vvedi</hi>
                    <lb n="3" break="no"/>-maṅkalattu <hi rend="grantha">śrī</hi>-veli-vi<hi rend="grantha">ṣṇu-gṛha</hi>ttu veḷḷai-m<choice><sic>u</sic><corr>ū</corr></choice><reg>r</reg>tti-y-āḻvārk=ku <hi rend="grantha">śrī</hi>-<choice><sic>ṉ</sic><corr>n</corr></choice>ār<choice><sic>a</sic><corr>ā</corr></choice>yaṇa-c-cēri-kilākkil caṉṉacaṭṭi <hi rend="grantha">kra</hi>mavitta<supplied reason="omitted">ṉ</supplied> vaitta <choice><sic>ṉ</sic><corr>n</corr></choice>antā-viḷak=ku Oṉṟiṉāl Āṭu toṇṇūṟṟ’ āṟu</p>
                
                <p>
                    It-toṇṇūṟṟ’ āṟuk=kum I<choice><orig>v</orig><reg>vv</reg></choice>-ūr periḷamaiyārē puṇai-y-ā<supplied reason="omitted">ka</supplied>-c cāvā m<choice><orig>u</orig><reg>ū</reg></choice>vā-p pēr-āṭ’ āka <hi rend="grantha">candrāditya</hi>vaṟ nicatam Uḻak=ku <choice><sic>n</sic><corr>n</corr></choice>ey muṭṭāmai Aṭṭuvippārkaḷ āka muṭṭil <hi rend="grantha">śraddhā</hi>mantarum <hi rend="grantha">śrī-vaiṣṇa</hi><supplied reason="omitted">va</supplied>rumē <hi rend="grantha">da<unclear reason="eccentric_ductus">ṇḍ</unclear>i</hi>ppār <choice><sic>a</sic><corr>ā</corr></choice>ka v<choice><sic>a</sic><corr>ai</corr></choice>ttō<supplied reason="subaudible">m</supplied> <hi rend="grantha">mahāsabhai</hi>yōm
                </p>
                
            </div>
            
