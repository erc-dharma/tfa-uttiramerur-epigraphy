                <ab>
                    <lb n="1"/><hi rend="grantha">svasti śrī</hi>
                </ab>
                
                <p>
                    kō-p-parake<hi rend="grantha">sa</hi>riva<hi rend="grantha">nma</hi>r-āṉa <hi rend="grantha"><unclear>śrī</unclear></hi>-<unclear>rā</unclear><hi rend="grantha"><unclear>jen</unclear><choice><orig><unclear>t</unclear></orig><reg>d</reg></choice><unclear>ra</unclear></hi>-cōḻa-<hi rend="grantha">de</hi>vark=ku yāṇṭu 4-Āvatu
                </p>
                
                <p>
                    <hi rend="grantha">ja</hi>yaṅ-koṇṭa-cōḻa-maṇṭalattu kā<unclear>li</unclear>yūr-kō<!--note kko-->ṭṭattu taṉ kūṟṟu Uttara-mēru-<hi rend="grantha">c-ca</hi>tu<hi rend="grantha"><unclear>r</unclear>vve</hi>ti-maṅ
                    <lb n="2" break="no"/>kalattu peruṅ-kuṟi-<hi rend="grantha">sabhai</hi>yōm Eḻuttu
                </p>
                <p>
                    namm-<choice><orig>u</orig><reg>ū</reg></choice>r veḷḷai-m<choice><orig>u</orig><reg>ū</reg></choice>rtti-Āḻvārk=ku koṅkaraiyar vilaik=ku <surplus><add place="above">ka la ta</add></surplus> koṇṭu vaitta kollaiv <hi rend="grantha">bhūmi</hi>
                </p>
               
