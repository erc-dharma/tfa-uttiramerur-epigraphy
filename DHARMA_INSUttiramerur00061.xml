            <div type="edition" xml:lang="tam-Latn" rendition="class:tamil maturity:83215">
                
                <ab>
                    <lb n="1"/><hi rend="grantha">svasti śrī</hi>
                </ab>
                
                <lg>
                    <l n="1">tiru-makaḷ pōla-p peru-<choice><sic>ṉ</sic><corr>n</corr></choice>ila-c-celviyun</l>
                    <l n="2">taṉakkē y-urim<hi rend="grantha">ai</hi> pūṇṭam<hi rend="grantha">ai</hi> <add place="below">ma</add>ṉakkoḷa-k</l>
                    <l n="3">kāntaḷūr-c cālai kalam arutt-aruḷi</l>
                    <l n="4">vēṅk<hi rend="grantha">ai</hi>-nāṭuṅ kaṅka-pāṭiyu<supplied reason="subaudible">m</supplied></l>
                    <l n="5"><choice><sic>ṉ</sic><corr>n</corr></choice>uḷam<supplied reason="omitted">pa</supplied>-pāṭiyun taṭik<hi rend="grantha">ai</hi>-pāṭiyuṅ</l>
                    <l n="6">kuṭa-malai-nāṭuṅ kollamuṅ ka<lb n="2" break="no"/>liṅkamum</l>
                    <l n="7">Eṇ-ṭic<hi rend="grantha">ai</hi> pukaḻ tara Īḻa-maṇṭalamum</l>
                    <!--<l n="8">Iṟaṭṭapāṭi Ēḻ’ arai y-ilak=kamun</l>-->
                    <l n="9">tiṇṭiṟal ve<choice><sic>n</sic><corr>ṉ</corr></choice>ṟi taṇṭā<supplied reason="omitted">ṟ</supplied>-k= ko<!--note kko-->ṇṭa taṉṉ</l>
                    <l n="10">eḻil vaḷar<surplus>u</surplus> Ūḻi Ellā yāṇṭun</l>
                    <l n="11">toḻutak<hi rend="grantha">ai</hi> viḷaṅkum yāṇṭē</l>
                    <l n="12">ceḻiyarai-t tēcu koḷ</l>
                </lg>
                
                <p>
                    <hi rend="grantha">śrī</hi>-kō-rā<hi rend="grantha">ja</hi>-rā<hi rend="grantha">ja</hi>-ke<hi rend="grantha">sa</hi>ri-pa<hi rend="grantha">nma</hi>r-āṉa <hi rend="grantha">śrī-rāja-rāja-</hi>tēvaṟku yā<lb n="3" break="no"/>ṇṭu Iru-pattu <choice><sic>ṉ</sic><corr>n</corr></choice>āl-āvatu
                </p>
                
                <p>
                    kāliyūr-k=-kō<!--note kko-->ṭṭattu taṉ kūṟṟu Utta<hi rend="grantha">ra-meru-c-caturvvedi-maṃga</hi>lattu <hi rend="grantha">śrī</hi>-veli-vi<hi rend="grantha">ṣṇu-gṛha</hi>ttu veḷḷai-mū<reg>r</reg>t=ti y-āḷvārkku <hi rend="grantha">śrī</hi>-nā<hi rend="grantha">rā</hi>yaṇa-c-cēri ciṅkippuṟattu Aiyaṉaṭikaḷ <hi rend="grantha">kra</hi>mavittaṉ vaitta <choice><sic>ṉ</sic><corr>n</corr></choice>antā-viḷak=ku O<choice><sic>n</sic><corr>ṉ</corr></choice>ṟiṉāl Ā<lb n="4" break="no"/>ṭu toṇṇūṟṟ’ āṟu</p>
                
                <p>
                    It-to<supplied reason="omitted">ṇṇūṟṟ’ ā</supplied>ṟukkum Ivv-ūr-p periḷam<hi rend="grantha">ai</hi>yārē puṇai-y-ā<supplied reason="omitted">ka</supplied>-c cāvā m<choice><orig>u</orig><reg>ū</reg></choice>vā-p pēr-āṭ’ āka <hi rend="grantha">candrādi</hi>ttavaṟ  nicatam Uḻak=ku <choice><sic>ṉ</sic><corr>n</corr></choice>ey muṭṭām<hi rend="grantha">ai</hi> Aṭṭuvippārkaḷ āka muṭṭil <hi rend="grantha">śraddhā</hi>mantarum <hi rend="grantha">śrīvaiṣṇa</hi>varumē <hi rend="grantha">daṇḍi</hi>ppār āka <hi rend="grantha">vai</hi>ttō<supplied reason="subaudible"/>m <hi rend="grantha">mahāsabhai</hi>yōm <g ref="sym:flourish-taperOut" type="punctuation">.</g>
                </p>
                
