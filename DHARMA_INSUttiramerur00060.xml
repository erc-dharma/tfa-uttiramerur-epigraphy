            <div type="edition" xml:lang="tam-Latn" rendition="class:tamil maturity:83215">
                
                <ab>
                    <lb n="1"/><hi rend="grantha">svasti śrī</hi>
                </ab>
                
                <lg>
                    <l n="1">tiru-makaḷ pōla-p peru-<choice><sic>ṉ</sic><corr>n</corr></choice>ila-c-ce<supplied reason="omitted">l</supplied>viyu<choice><sic>ṉ</sic><corr>n</corr></choice></l>
                    <l n="2">taṉakkē<!--note kke--> y-urim<hi rend="grantha">ai</hi> pūṇṭam<hi rend="grantha">ai</hi> maṉakkoḷa-k</l>
                    <l n="3">kāntaḷūr-c cā<lb n="2" break="no"/>lai kalam arutt-aruḷi</l>
                    <l n="4">vēṅk<hi rend="grantha">ai</hi>-nāṭum kaṅka-pāṭiyum</l>
                    <l n="5"><choice><sic>ṉ</sic><corr>n</corr></choice>uḷampa-pāṭiyum taṭik<hi rend="grantha">ai</hi>-pāṭiyum</l>
                    <l n="6">kuṭa-malai-nāṭum ko<lb n="3" break="no"/>llamum kaliṅkamum</l>
                    <l n="7">Eṇ-ṭicai pukaḻ tara Īḻa-maṇṭalamum</l>
                    <l n="8">Ilaṭṭa-pāṭi Ēḻ’ ar<hi rend="grantha">ai</hi> Ilak=kamum</l>
                    <l n="9">tiṇṭiṟal veṉṟi-t taṇṭ<lb n="4" break="no"/>āṟ-k-ko<!--kekā in fact-->ṇṭa taṉṉ</l>
                    <l n="10">eḻil vaḷar <choice><orig>u</orig><reg>ū</reg></choice>ḻi Ellā yāṇṭun</l>
                    <l n="11">toḻutak<hi rend="grantha">ai</hi> viḷaṅkum yāṇṭē</l>
                    <l n="12">ceḻiyar<hi rend="grantha">ai</hi><!--superposed kompu-->-t tē<!--teta in fact-->cu koḷ</l>
                </lg>
                <p>
                    <hi rend="grantha">śrī</hi>-kō-<hi rend="grantha">rāja-rāja</hi>-ke<hi rend="grantha">sa</hi>ri-van<hi rend="grantha">mar-ā</hi>ṉa <hi rend="grantha">śrī-rāja-rāja-</hi>tēvaṟku yāṇṭu Irupattu <choice><sic>ṉ</sic><corr>n</corr></choice>āl-vatu
                </p>
                
                <p>
                    kāliyūr-k=-kō<!--note kko-->ṭṭattu ta<choice><sic>n</sic><corr>ṉ</corr></choice> kūṟṟu Utta<hi rend="grantha">ra</hi>-meru-c-ca<surplus>n=</surplus>turvve<hi rend="grantha">di-maṅgala</hi>ttu <hi rend="grantha">śrī</hi>-veli-vi<hi rend="grantha">ṣṇu-gṛha</hi>t=tu veḷḷ<hi rend="grantha">ai</hi>-m<choice><orig>u</orig><reg>ū</reg></choice>rtti y-āḷvā<hi rend="grantha">r</hi>k=ku <hi rend="grantha">śrī-go</hi>vi<hi rend="grantha">nda</hi>-c-cēri-k=-ko<!--note kko-->ṭi-t<!--ASI: Ikkāṭṭi--> tāmōtira-<hi rend="grantha">bha</hi>ṭṭa<choice><sic>n</sic><corr>ṉ</corr></choice> vaitta <choice><sic>ṉ</sic><corr>n</corr></choice>an=tā
                    <lb n="5" break="no"/>-viḷak=ku Oṉṟuk=ku vaitta Āṭu toṇṇūṟṟ’ aṟu</p>
                <p>
                    maṉṟāṭi perumāṉ kaṇamoṭan kāl viḷakkāl vaitta Āṭu Iru-pattu nālum āka Oṉṟē kāl viḷakkālum Āṭu <choice><sic>ṇ</sic><corr>n</corr></choice>ūṟṟu Irupatum
                </p>
                <p>
                    I<choice><sic>ṉṉ</sic><corr>nn</corr></choice>ūṟṟu Irupatukkum Ivv-ūr-p periḷamaiyārē puṇai-y-ā<supplied reason="omitted">ka</supplied>-c cāvā m<choice><sic>u</sic><corr>ū</corr></choice>vā-p pēr-āṭ’ āka <hi rend="grantha">candrāditya</hi>vaṟ nicatam uḻak=ku <choice><sic>ṉ</sic><corr>n</corr></choice>ey muṭṭām<hi rend="grantha">ai</hi> Aṭṭuvippārkaḷ āka muṭṭil <hi rend="grantha">śraddhā</hi>mantarum <hi rend="grantha">śrīvaiṣṇ<choice><sic>u</sic><corr>a</corr></choice></hi>varumē <hi rend="grantha">daṇḍi</hi>ppār āka <hi rend="grantha">vai</hi>ttō<supplied reason="subaudible"></supplied>m <hi rend="grantha">mahāsabhai</hi>y<choice><sic>e</sic><corr>ō</corr></choice>m
                </p>
                
