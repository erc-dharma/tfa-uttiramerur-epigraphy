            <div type="edition" xml:lang="tam-Latn" rendition="class:tamil maturity:83215">
                
                <ab>
                    <lb n="1"/><hi rend="grantha">svasti śrī</hi>
                </ab>
                
                <lg>
                    <l n="1">tirumakaḷ pōla-p-perunila-c-celviyun=</l>
                    <l n="2">taṉak=kē y-urimai pūṇṭamai maṉak=koḷa-k=</l>
                    <l n="3">kān=taḷūr cālai kalamarutt-aruḷi</l>
                    <l n="4">vēṅkai-nāṭuṅ kaṅka-pāṭiyum</l>
                    <l n="5">nuḷampa-pāṭiyum taṭikai-pā<lb n="2" break="no"/>ṭiyuṅ</l>
                    <l n="6">kuṭamalai-nāṭuṅ kollamuṅ kaliṅkamum</l>
                    <l n="7">Eṇ-ṭicai pukaḻ tara Īḻamaṇṭalamum</l>
                    <l n="8">Ilaṭṭapāṭi Ēḻ’arai y-ilak=kamum</l>
                    <l n="9">tiṇtiṟal veṉṟi taṇṭāṟ <hi rend="grantha">ko</hi>ṇṭa taṉ<choice><orig>n</orig><reg>ṉ</reg></choice></l>
                    <l n="10">eḻil vaḷa<surplus>r</surplus><lb n="3" break="no"/>r<choice><orig>u</orig><reg>ū</reg></choice>ḻi Ellā yāṇṭun</l>
                    <l n="11">toḻutakai viḷaṅkum yāṇṭē</l>
                    <l n="12">ceḻiyarai-t tēcu koḷ</l>
                </lg>
                <p>
                    <hi rend="grantha">śrī</hi>-kō-rā<hi rend="grantha">ja-kesari-pa</hi>ṉ<hi rend="grantha">mār-ā</hi>ṉa <hi rend="grantha">śrī-rāja-rāja-de</hi>vaṟku y<unclear>ā</unclear>ṇṭu <num value="26">2 <g type="numeral">10</g> 6</num> Āvatu
                </p>
                
                <p>
                    kāliyūr-koṭ
                    <lb n="4" break="no"/>ṭat=tu taṉ-kūṟṟ’ ut=tara<hi rend="grantha">meru-c-catu<reg>r</reg>vve</hi>ti-<hi rend="grantha">maṃkala</hi>t=tu <hi rend="grantha">śrī</hi>-veli-vi<hi rend="grantha">ṣṇugṛha</hi>t=tu veḷḷai-m<choice><sic>u</sic><corr>ū</corr></choice><unclear>r</unclear>tti Āḻvārk=ku Ivv-ū<hi rend="grantha"><reg>r</reg> yyā</hi>ḻuṅkaṇattāruḷ <hi rend="grantha">śrī-go</hi>vi<hi rend="grantha">nda</hi>-c-cēri koṭṭi-c caṉṉa
                    <lb n="5" break="no"/>kumāra-k-<hi rend="grantha">kra</hi>mavittaṉ <hi rend="grantha">brahma</hi>ṇi naṅkai māticcāni vait=ta tiru-na<hi rend="grantha">ndā</hi>-viḷak=ku Oṉṟiṉāl Āṭu toṇṇūṟṟ’ āṟu</p>
                
                <p>
                    It-toṇṇūṟṟ’ āṟuk=ku’ āṭum I<choice><orig>v</orig><reg>vv</reg></choice>-ūr paṉmaiccēriyā
                    <lb n="6" break="no"/>rē puṇai-y-ā<supplied reason="omitted">ka</supplied>-c cāvā mūvā-p pēr-āṭ’ āka <hi rend="grantha">candrādityā</hi>vaṟ  nicatam Uḻak=ku ney muṭṭāmai Aṭṭuvippārkaḷ āka muṭṭil <hi rend="grantha">śraddha</hi>mantarum <hi rend="grantha">śrīvaiṣṇ<choice><sic>u</sic><corr>a</corr></choice></hi>varummē ta<hi rend="grantha">ṇḍi</hi>ppār āka vait=tōm <hi rend="grantha">mahāsabhai</hi>yōm paṇiyāl Eḻutiṉ<surplus>n</surplus>ēṉ Ayirat=t-iru-nūṟṟuva-p-peruṅ-kaṉṉāṉ-ēṉ
                </p>
                
